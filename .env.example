# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. `scripts/generate-secrets.sh` reads it and produces
# Sources/Generated/Secrets.swift at build time.

# Google OAuth Desktop client ID
# https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth client → Desktop app
# A client secret is NOT needed because we use PKCE.
CALLY_GOOGLE_CLIENT_ID=
