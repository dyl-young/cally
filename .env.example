# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. `scripts/generate-secrets.sh` reads it and produces
# Sources/Generated/Secrets.swift at build time.

# Google OAuth Desktop client (PKCE flow).
# https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth client → Desktop app
# Google's Desktop OAuth still requires the client_secret in token exchange even with PKCE,
# so both values are needed. The secret is "public" in installed-app sense — keep it out of source
# but treat it as low-sensitivity.
CALLY_GOOGLE_CLIENT_ID=
CALLY_GOOGLE_CLIENT_SECRET=
